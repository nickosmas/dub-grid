{
  "name": "dub-grid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "npx tsx --env-file=.env.local seed.ts",
    "db:reset": "supabase db reset && FORCE_LOCAL_DB=1 npm run seed",
    "db:reset:remote": "npm run use:remote && npx tsx --env-file=.env.local scripts/reset-remote-db.ts && npm run seed && npm run use:local",
    "use:local": "cp .env.local.bak .env.local && echo '✅ Switched to LOCAL Supabase (restart dev server)'",
    "use:remote": "cp .env.local .env.local.bak && cp .env.remote .env.local && echo '✅ Switched to REMOTE Supabase (restart dev server)'"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "cli-spinners": "^3.4.0",
    "clsx": "^2.1.1",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@snaplet/copycat": "^6.0.0",
    "@snaplet/seed": "^0.98.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.36",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^4.5.3",
    "jsdom": "^27.0.1",
    "kleur": "^4.1.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
